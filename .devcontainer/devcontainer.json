{
    "name": "fabric-cicd",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
    "features": {
        "ghcr.io/devcontainers-extra/features/git-lfs:1": {},
        "ghcr.io/devcontainers/features/node:2.0.0": {},
        "ghcr.io/devcontainers-extra/features/uv:1": {},
        "ghcr.io/devcontainers-extra/features/ruff:2": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "esbenp.prettier-vscode",
                "ms-vscode.powershell",
                "charliermarsh.ruff",
                "tamasfe.even-better-toml"
            ],
            "settings": {
                "python.defaultInterpreterPath": ".venv/bin/python",
                "ruff.path": [".venv/bin/ruff"],
                "autopep8.enable": false
            }
        }
    },
    "postCreateCommand": "npm install -g changie@1.19.0 && uv sync --dev",
    "forwardPorts": [8000]
}
