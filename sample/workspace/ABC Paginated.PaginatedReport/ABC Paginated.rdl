  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>ABC</DataSourceName>
        <CommandText>DEFINE VAR __DS0Core = 
	SUMMARIZECOLUMNS(
		ROLLUPADDISSUBTOTAL('Table'[Column1], "IsGrandTotalRowTotal"),
		"SumColumn1", CALCULATE(SUM('Table_2'[Column1]))
	)

EVALUATE
	__DS0Core

ORDER BY
	[IsGrandTotalRowTotal] DESC, 'Table'[Column1]</CommandText>
        <wa:PreviewCommandText>DEFINE
	VAR __DS0Core = 
		SUMMARIZECOLUMNS(
			ROLLUPADDISSUBTOTAL('Table'[Column1], "IsGrandTotalRowTotal"),
			"SumColumn1", CALCULATE(SUM('Table_2'[Column1]))
		)

	VAR __DS0BodyLimited = 
		TOPN(500, __DS0Core, [IsGrandTotalRowTotal], 0, 'Table'[Column1], 1)

EVALUATE
	__DS0BodyLimited

ORDER BY
	[IsGrandTotalRowTotal] DESC, 'Table'[Column1]</wa:PreviewCommandText>
      </Query>
      <Fields>
        <Field Name="Table_Column1">
          <DataField>Table[Column1]</DataField>
          <AggregateIndicatorField xmlns="http://schemas.microsoft.com/sqlserver/reporting/2011/01/reportdefinition">x_5b_IsGrandTotalRowTotal_5d_</AggregateIndicatorField>
        </Field>
        <Field Name="Table_5f_2_Column1">
          <DataField>[SumColumn1]</DataField>
        </Field>
        <Field Name="x_5b_IsGrandTotalRowTotal_5d_">
          <DataField>[IsGrandTotalRowTotal]</DataField>
        </Field>
      </Fields>
      <InterpretSubtotalsAsDetails>False</InterpretSubtotalsAsDetails>
    </DataSet>
  </DataSets>
